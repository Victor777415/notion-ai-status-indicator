{
  "name": "notion-ai-desktop-companion",
  "version": "0.1.0",
  "description": "Notion AI 桌面伴侣：常驻置顶小窗，实时显示所有 Notion AI 对话状态，点击跳转对应标签页。",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.victor.notion-ai-companion",
    "productName": "Notion AI 伴侣",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.png"
    }
  }
}
